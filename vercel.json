{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "framework": null,

  "cleanUrls": true,
  "trailingSlash": false,

  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/services.html", "destination": "/services", "permanent": true },
    { "source": "/tarifs.html", "destination": "/tarifs", "permanent": true },
    { "source": "/reservation.html", "destination": "/reservation", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/a-propos.html", "destination": "/a-propos", "permanent": true },
    { "source": "/mentions-legales.html", "destination": "/mentions-legales", "permanent": true },
    { "source": "/politique-confidentialite.html", "destination": "/politique-confidentialite", "permanent": true },

    { "source": "/portail-pro", "destination": "https://pro.maisonpaliquey.fr", "permanent": true },
    { "source": "/portail-pro.html", "destination": "https://pro.maisonpaliquey.fr", "permanent": true },
    { "source": "/portail-pro/", "destination": "https://pro.maisonpaliquey.fr", "permanent": true },

    { "source": "/linge-pro", "destination": "/services#location", "permanent": true },
    { "source": "/linge-pro/", "destination": "/services#location", "permanent": true },
    { "source": "/services/blanchisserie", "destination": "/services#blanchisserie", "permanent": true },
    { "source": "/services/pressing", "destination": "/services#pressing", "permanent": true },
    { "source": "/services/location-linge", "destination": "/services#location", "permanent": true },
    { "source": "/produits-ecologiques", "destination": "/a-propos", "permanent": true },
    { "source": "/produits", "destination": "/services", "permanent": true },
    { "source": "/blanchisserie", "destination": "/services#blanchisserie", "permanent": true },
    { "source": "/pressing", "destination": "/services#pressing", "permanent": true },
    { "source": "/location-de-linge", "destination": "/services#location", "permanent": true },
    { "source": "/professionnels", "destination": "https://pro.maisonpaliquey.fr", "permanent": true },
    { "source": "/pro", "destination": "https://pro.maisonpaliquey.fr", "permanent": true }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
